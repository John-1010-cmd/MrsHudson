# ============================================
# MrsHudson AI管家 - Git Ignore 配置
# ============================================

# ============================================
# 项目特定文件
# ============================================
# TTS语音合成生成的音频文件
uploads/
mrshudson-backend/uploads/

# IDE 项目文件
*.iml

# ============================================
# 敏感配置文件 (重要！)
# ============================================
# 环境变量文件 - 包含 API Keys、数据库密码等敏感信息
.env
.env.local
.env.*.local

# 本地环境特定的 Spring Boot 配置文件
application-local.yml
application-dev.yml
application-prod.yml
application-secret.yml

# ============================================
# 前端 (Vue 3 + Vite)
# ============================================
# Node.js 依赖目录
mrshudson-frontend/node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# 前端构建输出
mrshudson-frontend/dist/
mrshudson-frontend/dist-ssr/
mrshudson-frontend/build/

# Vite 缓存
mrshudson-frontend/node_modules/.vite/
*.vite

# 本地开发环境文件
mrshudson-frontend/*.local
mrshudson-frontend/.env.local
mrshudson-frontend/.env.*.local

# 前端测试覆盖率
coverage/
.nyc_output/

# TypeScript
*.tsbuildinfo

# ============================================
# Android 项目
# ============================================
# Gradle 文件
mrshudson-android/.gradle/
mrshudson-android/build/
mrshudson-android/app/build/
mrshudson-android/buildSrc/build/

# 本地配置文件
mrshudson-android/local.properties
mrshudson-android/*.properties
!mrshudson-android/gradle.properties

# Android Studio
mrshudson-android/.idea/
mrshudson-android/*.iml
mrshudson-android/.navigation/
mrshudson-android/captures/
mrshudson-android/.externalNativeBuild/
mrshudson-android/.cxx/

# Android 生成的文件
mrshudson-android/*.apk
mrshudson-android/*.ap_
mrshudson-android/*.aab
mrshudson-android/output.json

# 签名文件（绝对不能提交！）
mrshudson-android/*.jks
mrshudson-android/*.keystore
mrshudson-android/release.keystore
mrshudson-android/debug.keystore

# lint 报告
mrshudson-android/lint/intermediates/
mrshudson-android/lint/generated/
mrshudson-android/lint/outputs/
mrshudson-android/lint/tmp/

# ============================================
# 后端 (Spring Boot + Maven)
# ============================================
# Maven 构建输出
mrshudson-backend/target/
mrshudson-backend/*.jar
mrshudson-backend/*.war
mrshudson-backend/*.ear

# Maven 包装器（可选，如果希望共享可以删除此项）
# mrshudson-backend/.mvn/wrapper/maven-wrapper.jar

# Gradle（如果使用）
mrshudson-backend/.gradle/
mrshudson-backend/build/

# Gradle Wrapper (应该提交)
!mrshudson-android/gradle/wrapper/gradle-wrapper.jar
!mrshudson-backend/gradle/wrapper/gradle-wrapper.jar
!**/src/main/**/build/
!**/src/test/**/build/

# Spring Boot 特定
*.pid
hs_err_pid*
attach_pid*
spring-boot-*.pid

# ============================================
# IDE 和编辑器
# ============================================
# IntelliJ IDEA
.idea/
*.iml
*.iws
*.ipr
out/

# VS Code
.vscode/
*.code-workspace

# Eclipse
.classpath
.project
.settings/
.factorypath

# Visual Studio
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Fleet
.fleet/

# ============================================
# 日志文件
# ============================================
logs/
*.log
*.log.*
spring.log

# ============================================
# 操作系统文件
# ============================================
# macOS
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Linux
*~
.nfs*

# ============================================
# 数据库文件
# ============================================
# H2 数据库（如果使用）
*.h2.db
*.mv.db
*.trace.db

# ============================================
# Docker（本地构建文件）
# ============================================
# Docker 本地数据卷（如果有）
docker-data/
volumes/

# ============================================
# 临时和缓存文件
# ============================================
*.tmp
*.temp
*.cache
.cache/
*.pid
*.seed
*.pid.lock

# ============================================
# Claude Code AI 助手
# ============================================
.claude/

# ============================================
# Spec Workflow (可选)
# ============================================
spec-workflow/approvals/
.spec-workflow/approvals/
.spec-workflow/**/Implementation Logs/

# ============================================
# 其他
# ============================================
# 压缩文件（通常不应该提交）
*.zip
*.tar.gz
*.rar
*.7z

# 备份文件
*.bak
*.backup

# 本地脚本（个人使用）
local-*.sh
local-*.bat
local-*.ps1

# ============================================
# 测试相关
# ============================================
test-output/
surefire-reports/
failsafe-reports/
*.test-result

# ============================================
# 部署相关
# ============================================
.env.production
.env.staging
kubernetes/secrets/
helm/charts/
.terraform/
