<?xml version="1.0" encoding="UTF-8"?>
<!-- 
  Logback 配置文件 - 确保日志使用 UTF-8 编码
  解决 Windows 平台日志中文乱码问题
-->
<configuration>
    <!-- 设置日志上下文名称 -->
    <contextName>mrshudson</contextName>
    
    <!-- 控制台日志输出 -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <!-- 立即刷新 -->
        <immediateFlush>true</immediateFlush>
        <!-- 强制使用 UTF-8 编码 -->
        <encoder class="ch.qos.logback.classic.encoder.PatternLayoutEncoder">
            <charset>UTF-8</charset>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n</pattern>
        </encoder>
        <!-- 确保输出流使用 UTF-8 -->
        <target>System.out</target>
    </appender>

    <!-- 文件日志输出 -->
    <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>logs/mrshudson.log</file>
        <append>true</append>
        <immediateFlush>true</immediateFlush>
        <encoder class="ch.qos.logback.classic.encoder.PatternLayoutEncoder">
            <charset>UTF-8</charset>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n</pattern>
        </encoder>
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <fileNamePattern>logs/mrshudson.%d{yyyy-MM-dd}.log</fileNamePattern>
            <maxHistory>30</maxHistory>
        </rollingPolicy>
    </appender>

    <!-- 根日志级别 -->
    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
        <appender-ref ref="FILE"/>
    </root>

    <!-- 应用日志级别 -->
    <logger name="com.mrshudson" level="DEBUG"/>
    <logger name="org.springframework.web" level="INFO"/>
</configuration>
