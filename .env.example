# MrsHudson 环境变量配置模板
# 复制此文件为 .env 并填写实际值，然后运行: docker-compose up -d mysql redis

# ============================================
# MySQL 数据库配置（开发环境默认可不修改）
# ============================================
MYSQL_ROOT_PASSWORD=mrshudson_root
MYSQL_DATABASE=mrshudson
MYSQL_USER=mrshudson
MYSQL_PASSWORD=mrshudson_pass

# ============================================
# Redis 缓存配置（开发环境默认可不修改）
# ============================================
REDIS_PASSWORD=mrshudson_redis

# ============================================
# AI 模型配置 【必填】
# 从 https://platform.moonshot.cn/ 获取 API Key
# ============================================
KIMI_API_KEY=your-kimi-api-key-here

# ============================================
# 天气 API 配置【启用天气查询功能必填】
# 从 https://lbs.amap.com/api/webservice/guide/api/weatherinfo 获取 API Key
# 未配置时天气查询将返回错误：INVALID_USER_KEY
# ============================================
WEATHER_API_KEY=your-weather-api-key-here

# ============================================
# 讯飞语音服务配置（可选）
# 从 https://www.xfyun.cn/ 获取
# 当前为模拟模式，如需真实语音识别请配置
# ============================================
XFYUN_APP_ID=
XFYUN_API_SECRET=
XFYUN_API_KEY=

# ============================================
# JVM 配置（可选）
# ============================================
JAVA_OPTS=-Xms512m -Xmx1024m
