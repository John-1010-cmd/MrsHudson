# MrsHudson 环境变量配置模板
# 复制此文件为 .env 并填写实际值

# ============================================
# MySQL 数据库配置
# ============================================
MYSQL_ROOT_PASSWORD=mrshudson_root
MYSQL_DATABASE=mrshudson
MYSQL_USER=mrshudson
MYSQL_PASSWORD=mrshudson_pass

# ============================================
# Redis 缓存配置
# ============================================
REDIS_PASSWORD=mrshudson_redis

# ============================================
# Kimi AI API 配置
# 从 https://platform.moonshot.cn/ 获取 API Key
# ============================================
KIMI_API_KEY=your-kimi-api-key-here

# ============================================
# 天气 API 配置
# 从 https://www.weatherapi.com/ 或其他天气服务获取
# ============================================
WEATHER_API_KEY=your-weather-api-key-here

# ============================================
# JVM 配置（可选）
# ============================================
JAVA_OPTS=-Xms512m -Xmx1024m
