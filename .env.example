# MrsHudson 环境变量配置模板
# 复制此文件为 .env 并填写实际值，然后运行: docker-compose up -d mysql redis

# ============================================
# MySQL 数据库配置（开发环境默认可不修改）
# ============================================
MYSQL_ROOT_PASSWORD=mrshudson_root
MYSQL_DATABASE=mrshudson
MYSQL_USER=mrshudson
MYSQL_PASSWORD=mrshudson_pass

# ============================================
# Redis 缓存配置（开发环境默认可不修改）
# ============================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=mrshudson_redis
REDIS_DATABASE=0

# ============================================
# AI 模型配置 【必填】
# AI_PROVIDER: 可选 kimi (默认) / minimax
# Kimi: https://platform.moonshot.cn/
# MiniMax: https://platform.minimax.cn/
# ============================================
AI_PROVIDER=kimi
KIMI_API_KEY=your-kimi-api-key-here
MINIMAX_API_KEY=your-minimax-api-key-here

# ============================================
# JWT 认证配置【生产环境建议配置】
# 用于 JWT Token 签名，建议使用至少 256 位的随机字符串
# 生成命令: openssl rand -base64 32
# 不配置时将使用默认内置密钥（仅适用于开发环境）
# ============================================
# JWT_SECRET=your-256-bit-secret-key-change-in-production

# ============================================
# 天气 API 配置【启用天气查询和路线规划功能必填】
# 从 https://lbs.amap.com/api/webservice/guide/api/weatherinfo 获取 API Key
# 路线规划功能也依赖此密钥
# 从 https://lbs.amap.com/api/webservice/guide/api/weatherinfo 获取 API Key
# 未配置时天气查询将返回错误：INVALID_USER_KEY
# ============================================
WEATHER_API_KEY=your-weather-api-key-here

# ============================================
# 讯飞语音服务配置（可选）
# 从 https://www.xfyun.cn/ 获取
# 当前为模拟模式，如需真实语音识别请配置
# ============================================
XFYUN_APP_ID=
XFYUN_API_SECRET=
XFYUN_API_KEY=

# ============================================
# Firebase 配置（可选，用于 Android 推送）
# 从 Firebase Console 下载服务账号私钥到 backend/src/main/resources/firebase-service-account.json
# ============================================
FIREBASE_PROJECT_ID=mrshudson-5b2fc

# ============================================
# JVM 配置（可选）
# ============================================
JAVA_OPTS=-Xms512m -Xmx1024m

# ============================================
# 向量数据库配置（AI调用成本优化 - 语义缓存）
# ============================================

# 向量存储类型: redis(简化版), chroma(推荐), milvus(大规模), none(禁用)
VECTOR_STORE_TYPE=redis

# Chroma 配置（当 VECTOR_STORE_TYPE=chroma 时使用）
CHROMA_HOST=localhost
CHROMA_PORT=8000

# Milvus 配置（当 VECTOR_STORE_TYPE=milvus 时使用）
# MILVUS_HOST=localhost
# MILVUS_PORT=19530

# ============================================
# 语义缓存配置（AI调用成本优化）
# ============================================

# 是否启用语义缓存
SEMANTIC_CACHE_ENABLED=true

# 相似度阈值 (0.0-1.0)，越高要求越严格，建议 0.85-0.95
SEMANTIC_CACHE_SIMILARITY_THRESHOLD=0.92

# 每用户最大缓存条目数
SEMANTIC_CACHE_MAX_ENTRIES_PER_USER=1000

# 缓存过期天数 (0 表示永不过期)
SEMANTIC_CACHE_TTL_DAYS=7

# ============================================
# AI 调用成本优化配置
# ============================================

# 是否启用意图路由 (将工具查询直接路由，跳过AI)
INTENT_ROUTER_ENABLED=true

# 意图路由器模式: rule-only(纯规则) / hybrid(三层混合) / ai-only(纯AI)
INTENT_ROUTER_MODE=hybrid

# 意图识别置信度阈值 (低于此值将走AI处理)
INTENT_ROUTER_CONFIDENCE_THRESHOLD=0.7

# ============================================
# 三层混合意图路由配置 (当 INTENT_ROUTER_MODE=hybrid 时生效)
# ============================================

# 第1层：规则提取层（已启用，零AI成本）
RULE_EXTRACTION_ENABLED=true

# 第2层：轻量AI提取层（规则失败时使用）
LIGHTWEIGHT_AI_ENABLED=true
LIGHTWEIGHT_AI_MAX_TOKENS=100
LIGHTWEIGHT_AI_TIMEOUT_MS=2000
# 轻量AI使用的模型（可与主模型不同，使用更便宜的）
LIGHTWEIGHT_AI_MODEL=moonshot-v1-8k

# 第3层：完整AI工具层（保底，无法避免）
FULL_AI_FALLBACK_ENABLED=true

# 是否启用对话历史压缩
CONVERSATION_COMPRESSION_ENABLED=true

# 触发压缩的消息数阈值
CONVERSATION_COMPRESSION_THRESHOLD=10

# 是否启用工具结果缓存
TOOL_CACHE_ENABLED=true

# 天气缓存TTL（秒）
WEATHER_CACHE_TTL=600

# 日历缓存TTL（秒）
CALENDAR_CACHE_TTL=120

# 待办缓存TTL（秒）
TODO_CACHE_TTL=120

# ============================================
# 成本监控配置
# ============================================

# 是否启用成本监控
COST_MONITOR_ENABLED=true

# 每日成本告警阈值（元）
COST_DAILY_ALERT_THRESHOLD=50

# 单用户每日调用次数告警阈值
COST_USER_DAILY_CALL_THRESHOLD=100

# ============================================
# Intent Vector Cache 配置（三层意图识别缓存）
# L1: 内存缓存 (Caffeine) - 5分钟 TTL
# L2: Redis Hash - 7天 TTL
# L3: Redis Vector (HNSW) - 30天 TTL (需要 Redis 7.2+ with RediSearch)
# ============================================

# 是否启用 Intent Vector Cache
INTENT_CACHE_ENABLED=true

# L1 缓存配置
INTENT_CACHE_L1_ENABLED=true

# L2 缓存配置
INTENT_CACHE_L2_ENABLED=true

# L3 缓存配置（需要 Redis 7.2+ with RediSearch）
INTENT_CACHE_L3_ENABLED=false
INTENT_CACHE_L3_SIMILARITY_THRESHOLD=0.92
# MiniMax: 768, Kimi: 1536
INTENT_CACHE_L3_VECTOR_DIMENSION=768

# 熔断器配置
INTENT_CACHE_CB_ENABLED=true
INTENT_CACHE_CB_FAILURE_THRESHOLD=10
INTENT_CACHE_CB_WAIT_DURATION=60
INTENT_CACHE_CB_SUCCESS_THRESHOLD=3
INTENT_CACHE_CB_WINDOW_SIZE=100

# ============================================
# TTS 语音合成配置
# ============================================

# TTS 服务提供商: xfyun (讯飞, 默认) / minimax / none (禁用)
TTS_PROVIDER=xfyun

# MiniMax TTS 配置（当 TTS_PROVIDER=minimax 时使用）
# 可选模型: speech-2.6-turbo, speech-2.6, speech-2.5, speech-2.0
MINIMAX_TTS_MODEL=speech-2.6-turbo
